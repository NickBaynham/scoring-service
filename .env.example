# Application
APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
API_KEY=

# Database (async SQLAlchemy URL)
DATABASE_URL=postgresql+asyncpg://scoring:scoring@localhost:5432/scoring

# OpenAI-compatible API
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-4o-mini
LLM_TIMEOUT_SECONDS=120
LLM_MAX_RETRIES=3

# Object storage (S3-compatible; optional for local dev)
S3_BUCKET=
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=
# For LocalStack/MinIO: AWS_ENDPOINT_URL=http://localhost:4566

# Worker queue: database (poll Postgres) or sqs
JOB_QUEUE_BACKEND=database
SQS_QUEUE_URL=
SQS_VISIBILITY_TIMEOUT_SECONDS=900

# Worker
WORKER_POLL_INTERVAL_SECONDS=2
WORKER_BATCH_SIZE=1

# Telemetry (optional)
OTEL_EXPORTER_OTLP_ENDPOINT=
